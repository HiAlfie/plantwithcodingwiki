---
import { highlightLAU } from '../utils/highlighter.js';

interface Props {
  title: string;
  language?: string;
  defaultOpen?: boolean;
  code?: string;
}
const { title, language = 'lau', defaultOpen = false, code } = Astro.props;

const highlightedCode = code ? highlightLAU(code) : '';
---

<div class="reveal-on-scroll code-accordion mb-6">
  <div class="rounded-xl overflow-hidden border" style="border-color: var(--border-color);">
    <button
      class="code-accordion-toggle w-full flex items-center justify-between px-5 py-3.5 transition-colors duration-200 cursor-pointer"
      style="background-color: var(--code-header-bg);"
      aria-expanded={defaultOpen ? 'true' : 'false'}
    >
      <div class="flex items-center gap-3">
        <div class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-400/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
        </div>
        <span class="text-sm font-mono text-gray-300">{title}</span>
        <span class="px-2 py-0.5 rounded text-[10px] font-mono uppercase tracking-wider bg-lau-500/20 text-lau-400">
          {language}
        </span>
      </div>
      <div class="flex items-center gap-2">
        <span class="copy-btn text-xs text-gray-400 hover:text-white transition-colors px-2 py-1 rounded hover:bg-white/10" title="Copy code">
          📋
        </span>
        <svg class="w-4 h-4 text-gray-400 transition-transform duration-300 accordion-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
    </button>

    <div class="code-accordion-body overflow-hidden transition-all duration-500" style={defaultOpen ? '' : 'max-height: 0;'}>
      <div class="p-5 font-mono text-sm leading-relaxed overflow-x-auto" style="background-color: var(--bg-code); color: #e2e8f0;">
        {code ? (
          <Fragment set:html={highlightedCode} />
        ) : (
          <slot>
            <div>
              <span class="text-purple-400">plant</span><span class="text-gray-300">(</span><span class="text-yellow-300">"sunflower"</span><span class="text-gray-300">)</span>
            </div>
            <div>
              <span class="text-purple-400">water</span><span class="text-gray-300">(</span><span class="text-lau-300">amount:</span><span class="text-orange-300"> 5</span><span class="text-gray-300">)</span>
            </div>
          </slot>
        )}
      </div>
    </div>
  </div>
</div>

<script is:inline>
  document.querySelectorAll('.code-accordion-toggle').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      if (e.target.closest('.copy-btn')) return;
      const body = btn.nextElementSibling;
      const chevron = btn.querySelector('.accordion-chevron');
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        body.style.maxHeight = '0';
        chevron.style.transform = 'rotate(0deg)';
        btn.setAttribute('aria-expanded', 'false');
      } else {
        body.style.maxHeight = body.scrollHeight + 'px';
        chevron.style.transform = 'rotate(180deg)';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const body = btn.closest('.code-accordion').querySelector('.code-accordion-body');
      const text = body.innerText;
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = '✅';
        setTimeout(() => { btn.textContent = '📋'; }, 1500);
      });
    });
  });

  document.querySelectorAll('.code-accordion-toggle[aria-expanded="true"]').forEach((btn) => {
    const body = btn.nextElementSibling;
    body.style.maxHeight = body.scrollHeight + 'px';
  });
</script>
