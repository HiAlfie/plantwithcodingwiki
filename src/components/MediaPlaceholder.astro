---
interface Props {
  type?: 'image' | 'video';
  aspectRatio?: string;
  caption?: string;
}
const { type = 'image', aspectRatio = '16/9', caption = '' } = Astro.props;
---

<div class="reveal-on-scroll mb-8">
  <div
    class="relative rounded-2xl overflow-hidden border-2 border-dashed transition-all duration-300 hover:border-lau-500/40 group"
    style={`border-color: var(--media-border); background-color: var(--media-bg); aspect-ratio: ${aspectRatio};`}
  >
    <slot>
      <div class="absolute inset-0 flex flex-col items-center justify-center gap-4 p-6">
        {type === 'video' ? (
          <div class="w-20 h-20 rounded-full flex items-center justify-center border-2 transition-all duration-300 group-hover:scale-110 group-hover:border-lau-500 group-hover:bg-lau-500/10"
            style="border-color: var(--border-color);">
            <svg class="w-8 h-8 ml-1 transition-colors duration-300 group-hover:text-lau-500" style="color: var(--text-muted);" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="5 3 19 12 5 21 5 3"/>
            </svg>
          </div>
        ) : (
          <div class="w-16 h-16 rounded-xl flex items-center justify-center transition-all duration-300 group-hover:scale-110"
            style="background-color: var(--border-color);">
            <svg class="w-8 h-8" style="color: var(--text-muted);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
        )}
        <div class="text-center">
          <p class="text-sm font-medium" style="color: var(--text-secondary);">
            {type === 'video' ? 'Insert Video Here' : 'Insert Image Here'}
          </p>
          <p class="text-xs mt-1" style="color: var(--text-muted);">
            {type === 'video' ? 'Embed a YouTube/Vimeo link or upload an MP4' : 'Drag & drop or paste an image URL'}
          </p>
        </div>
      </div>
    </slot>
  </div>

  {caption && (
    <p class="text-center text-sm mt-3 italic" style="color: var(--text-muted);">
      {caption}
    </p>
  )}
</div>
