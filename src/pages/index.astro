---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CategoryCard from '../components/CategoryCard.astro';
import CodeBlock from '../components/CodeBlock.astro';
import MediaPlaceholder from '../components/MediaPlaceholder.astro';
---

<BaseLayout>

  <HeroSection />

  <section id="categories" class="py-20 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal-on-scroll">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold tracking-wider uppercase mb-4 border"
          style="color: var(--text-muted); border-color: var(--border-color); background-color: var(--bg-card);">
          Browse Topics
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--text-primary);">
          Tutorial Categories
        </h2>
        <p class="text-base max-w-2xl mx-auto" style="color: var(--text-secondary);">
          Explore the LAU language through structured tutorials — from planting your first seed to automating entire garden ecosystems.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <CategoryCard
          icon="🌱"
          title="General"
          description="Learn the basics of the editor, scripts, and the farm environment."
          tag="Beginner"
          color="#22c55e"
          delay="delay-100"
          href={`${import.meta.env.BASE_URL}learn/general`}
        />
        <CategoryCard
          icon="⚡"
          title="Programming"
          description="Master the syntax, variables, structures, and functions of LAU."
          tag="Core Concept"
          color="#3b82f6"
          delay="delay-200"
          href={`${import.meta.env.BASE_URL}learn/programming`}
        />
        <CategoryCard
          icon="📚"
          title="Standard Library"
          description="Explore built-in modules like Math, Market, Drone, and more."
          tag="Reference"
          color="#8b5cf6"
          delay="delay-300"
          href={`${import.meta.env.BASE_URL}learn/standard-library`}
        />
        <CategoryCard
          icon="🎮"
          title="Game"
          description="Understand plants, seeds, weather, and marketplace mechanics."
          tag="Mechanics"
          color="#ef4444"
          delay="delay-400"
          href={`${import.meta.env.BASE_URL}learn/game`}
        />
      </div>
    </div>
  </section>

  <section id="code-examples" class="py-20 sm:py-28" style="background-color: var(--bg-secondary);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal-on-scroll">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold tracking-wider uppercase mb-4 border"
          style="color: var(--text-muted); border-color: var(--border-color); background-color: var(--bg-card);">
          Interactive Examples
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--text-primary);">
          Code Snippets
        </h2>
        <p class="text-base max-w-2xl mx-auto" style="color: var(--text-secondary);">
          Click any block to expand and explore. Copy snippets directly into your game console.
        </p>
      </div>

      <CodeBlock title="hello_garden.lau" language="lau" defaultOpen={true}>
        <div>
          <span class="text-purple-400">garden</span><span class="text-gray-300">.</span><span class="text-blue-300">create</span><span class="text-gray-300">(</span><span class="text-yellow-300">"My First Garden"</span><span class="text-gray-300">)</span>
        </div>
        <div>
          <span class="text-purple-400">plant</span><span class="text-gray-300">(</span><span class="text-yellow-300">"sunflower"</span><span class="text-gray-300">, </span><span class="text-blue-300">x:</span><span class="text-orange-300"> 0</span><span class="text-gray-300">, </span><span class="text-blue-300">y:</span><span class="text-orange-300"> 0</span><span class="text-gray-300">)</span>
        </div>
        <div>
          <span class="text-purple-400">water</span><span class="text-gray-300">(</span><span class="text-blue-300">amount:</span><span class="text-orange-300"> 3</span><span class="text-gray-300">)</span>
        </div>
        <div>
          <span class="text-purple-400">wait</span><span class="text-gray-300">(</span><span class="text-orange-300">10</span><span class="text-gray-300">)</span>
        </div>
        <div>
          <span class="text-purple-400">harvest</span><span class="text-gray-300">()</span>
        </div>
      </CodeBlock>

      <CodeBlock title="auto_farm.lau" language="lau">
        <div class="mt-2">
          <span class="text-pink-400">loop</span><span class="text-gray-300"> (</span><span class="text-blue-300">count:</span><span class="text-orange-300"> 5</span><span class="text-gray-300">) {'{'}</span>
        </div>
        <div>
          <span class="text-gray-300">  </span><span class="text-purple-400">plant</span><span class="text-gray-300">(</span><span class="text-yellow-300">"carrot"</span><span class="text-gray-300">)</span>
        </div>
        <div>
          <span class="text-gray-300">  </span><span class="text-purple-400">water</span><span class="text-gray-300">(</span><span class="text-blue-300">amount:</span><span class="text-orange-300"> 2</span><span class="text-gray-300">)</span>
        </div>
        <div>
          <span class="text-gray-300">  </span><span class="text-purple-400">wait</span><span class="text-gray-300">(</span><span class="text-orange-300">5</span><span class="text-gray-300">)</span>
        </div>
        <div>
          <span class="text-gray-300">{'}'}</span>
        </div>
      </CodeBlock>

      <CodeBlock title="custom_function.lau" language="lau">
        <div class="mt-2">
          <span class="text-pink-400">func</span><span class="text-gray-300"> </span><span class="text-blue-300">plantRow</span><span class="text-gray-300">(</span><span class="text-blue-300">type</span><span class="text-gray-300">, </span><span class="text-blue-300">count</span><span class="text-gray-300">) {'{'}</span>
        </div>
        <div>
          <span class="text-gray-300">  </span><span class="text-pink-400">loop</span><span class="text-gray-300"> (</span><span class="text-blue-300">count</span><span class="text-gray-300">) {'{'}</span>
        </div>
        <div>
          <span class="text-gray-300">    </span><span class="text-purple-400">plant</span><span class="text-gray-300">(</span><span class="text-blue-300">type</span><span class="text-gray-300">)</span>
        </div>
        <div>
          <span class="text-gray-300">  {'}'}</span>
        </div>
        <div>
          <span class="text-gray-300">{'}'}</span>
        </div>
        <div class="mt-2">
          <span class="text-blue-300">plantRow</span><span class="text-gray-300">(</span><span class="text-yellow-300">"tulip"</span><span class="text-gray-300">, </span><span class="text-orange-300">8</span><span class="text-gray-300">)</span>
        </div>
      </CodeBlock>
    </div>
  </section>

  <section id="media" class="py-20 sm:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal-on-scroll">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold tracking-wider uppercase mb-4 border"
          style="color: var(--text-muted); border-color: var(--border-color); background-color: var(--bg-card);">
          Visual Guides
        </span>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4" style="color: var(--text-primary);">
          Images &amp; Video Demos
        </h2>
        <p class="text-base max-w-2xl mx-auto" style="color: var(--text-secondary);">
          Visual demonstrations, screenshots, and video walkthroughs of LAU in action.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <MediaPlaceholder type="video" caption="Video Demo: Getting Started with LAU" />
        <MediaPlaceholder type="image" caption="Screenshot: The LAU Code Editor Interface" />
        <MediaPlaceholder type="image" aspectRatio="4/3" caption="Screenshot: Garden Growth Visualization" />
        <MediaPlaceholder type="video" aspectRatio="4/3" caption="Video Demo: Automation Loop in Action" />
      </div>
    </div>
  </section>

  <section class="py-20" style="background-color: var(--bg-secondary);">
    <div class="max-w-3xl mx-auto px-4 text-center reveal-on-scroll">
      <div class="rounded-2xl p-10 sm:p-14 border" style="background-color: var(--bg-card); border-color: var(--border-color);">
        <div class="text-4xl mb-4">🌻</div>
        <h2 class="text-2xl sm:text-3xl font-bold mb-4" style="color: var(--text-primary);">
          Ready to Start Growing?
        </h2>
        <p class="text-base mb-8 max-w-lg mx-auto" style="color: var(--text-secondary);">
          Jump into the tutorials, experiment with code snippets, and start building your dream garden — one line of LAU at a time.
        </p>
        <a href={`${import.meta.env.BASE_URL}learn`}
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-gradient-to-r from-lau-500 to-lau-600 text-white font-semibold shadow-lg shadow-lau-500/25 hover:shadow-lau-500/40 hover:scale-[1.03] active:scale-[0.98] transition-all duration-300">
          Browse Tutorials
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
